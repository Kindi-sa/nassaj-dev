# CloudCLI UI Environment Configuration
# Only includes variables that are actually used in the code
#
# TIP: Run 'cloudcli status' to see where this file should be located
#      and to view your current configuration.
#
# Available CLI commands:
#   claude-code-ui    - Start the server (default)
#   cloudcli start    - Start the server
#   cloudcli status   - Show configuration and data locations
#   cloudcli help     - Show help information
#   cloudcli version  - Show version information

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Backend server port (Express API + WebSocket server)
#API server
SERVER_PORT=3001
#Frontend port
VITE_PORT=5173

# Host/IP to bind servers to (default: 0.0.0.0 for all interfaces)
# Use 127.0.0.1 to restrict to localhost only
HOST=0.0.0.0

# CORS allowed origins — comma-separated list of full origins (scheme + host + optional port).
# If unset, the server allows: nassaj.alkindy.tech,
# localhost:3004, localhost:3001, localhost:5173.
# Requests with no Origin header (curl, server-to-server) are always allowed.
# Changes take effect after server restart.
# ALLOWED_ORIGINS=https://nassaj.alkindy.tech,http://localhost:3004

# Uncomment the following line if you have a custom claude cli path other than the default "claude"
# CLAUDE_CLI_PATH=claude

# -----------------------------------------------------------------------------
# UPGRADE NOTE — Claude base-URL guard (fail-closed)
# -----------------------------------------------------------------------------
# Every Claude spawn is gated by a fail-closed guard that rejects any *_BASE_URL
# (env or settings.json) whose host is not the official Anthropic API, an engaged
# per-user engine provider, or an explicit operator escape hatch. The default
# install sets no base URL, so this is invisible. BUT if you (or your shell/PM2
# env) set ANTHROPIC_BASE_URL to a company proxy / LiteLLM / gateway, the guard
# will refuse to spawn unless you allow that host below. Pick ONE:
#
#   * Proxy / gateway (most common): list its hostname(s), comma/space-separated.
# NASSAJ_ALLOWED_ANTHROPIC_HOSTS=proxy.internal.example, gateway.corp.example
#
#   * Amazon Bedrock routing (Claude Code reads regional AWS hosts):
# CLAUDE_CODE_USE_BEDROCK=1
#
#   * Google Vertex routing (Claude Code reads regional GCP hosts):
# CLAUDE_CODE_USE_VERTEX=1

# =============================================================================
# VENDOR-RESILIENCE GUARD (Claude/Anthropic subprocess)
# =============================================================================
# Iron rule (enforced in code, fail-closed): the Claude Code / Anthropic path
# must NEVER be pointed at a non-Anthropic / competitor endpoint. Before the
# Claude subprocess is spawned, server/services/isolation/anthropic-base-url-guard.js
# validates ANTHROPIC_BASE_URL (and its SDK-honored siblings
# ANTHROPIC_BEDROCK_BASE_URL / ANTHROPIC_VERTEX_BASE_URL): if any is SET to a host
# that is not approved, the server REFUSES to spawn. Any UNKNOWN endpoint-routing
# override (a *_BASE_URL under the ANTHROPIC_/CLAUDE_ namespace) is also refused.
# If these are UNSET (the nassaj-dev default), the guard is a no-op and the
# standard Anthropic path is used. The same allowlist is applied to the per-user
# settings.json `env` block inside each CLAUDE_CONFIG_DIR (which the CLI honors
# downstream of the spawn env) — a competitor base URL there cannot bypass it.
#
# Approved hosts: official Anthropic (api.anthropic.com / *.anthropic.com),
# official Bedrock (*.amazonaws.com when CLAUDE_CODE_USE_BEDROCK is enabled) and
# Vertex (*.googleapis.com when CLAUDE_CODE_USE_VERTEX is enabled), PLUS any host
# listed below.
#
# Escape hatch — ONLY for a legitimate Anthropic-backed proxy / credit-pool
# gateway / multi-user routing layer. Comma-separated list of hosts (or full
# URLs; reduced to host). A parent-domain entry also covers its subdomains.
# Do NOT add a competitor endpoint here, and do NOT remove the guard.
# NASSAJ_ALLOWED_ANTHROPIC_HOSTS=claude-gateway.corp.example.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Path to the authentication database file
# This is where user credentials, API keys, and tokens are stored.
#
# To use a custom location:
# DATABASE_PATH=/path/to/your/custom/auth.db
#
# Claude Code context window size (maximum tokens per session)
# CONTEXT_WINDOW=  # اتركه فارغاً/معلّقاً ليُستنتَج من الموديل (opus / sonnet 4.6+ = 1M). اضبط رقماً فقط لفرض override.

# =============================================================================
# AUTH (Phase-MU multi-user)
# =============================================================================
# JWT signing secret used to sign/verify stateless tokens. Must be >= 32 chars.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Keep the real .env file chmod 600. If unset, a per-install secret is generated
# and stored in app_config (works out of the box, but env is preferred).
# JWT_SECRET=
#
# Bootstrap owner — created automatically on first run if no owner exists.
# Defaults username to "owner". If BOOTSTRAP_OWNER_PASSWORD is unset, a strong
# random password is generated and printed ONCE to the server log.
# BOOTSTRAP_OWNER_USERNAME=owner
# BOOTSTRAP_OWNER_PASSWORD=
#
# Passkeys (WebAuthn) — relying party identity. Required in production for
# passkey login to work on the deployed domain; without them the server falls
# back to a localhost-only dev config (rpID=localhost, origin=http://localhost:5173).
# WEBAUTHN_RP_ID: registrable domain only (no scheme, no port).
# WEBAUTHN_ORIGIN: full origin(s) incl. scheme; comma-separated list supported.
# WEBAUTHN_RP_NAME: human-readable app name shown in browser passkey prompts.
# WEBAUTHN_RP_ID=example.com
# WEBAUTHN_ORIGIN=https://example.com
# WEBAUTHN_RP_NAME=Nassaj


