.env.test.local
.env.production.local

# Per-node PM2 ecosystem files (host-specific, generated by bootstrap-node.sh with
# inline secrets/port/DB path). The runnable node file `ecosystem.<node>.config.cjs`
# and any local `ecosystem.config.cjs` must NOT be tracked — tracking them would leak
# host secrets and reintroduce the traventure outage. Only the host-neutral reference
# template `ecosystem.config.example.cjs` stays tracked (negated below).
ecosystem.config.cjs
ecosystem.*.config.cjs
!ecosystem.config.example.cjs

